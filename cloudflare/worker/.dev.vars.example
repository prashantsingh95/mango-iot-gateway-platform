# Local development variables for `wrangler dev`.
# Copy to `.dev.vars` (git-ignored) and fill in real values.
# In production, set JWT_SECRET as an encrypted secret:
#   wrangler secret put JWT_SECRET

BACKEND_URL=http://localhost:3001
JWT_SECRET=change-me-must-match-backend-jwt-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
