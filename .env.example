# =============================================================================
# Mango IoT Gateway Platform — root environment (Docker Compose)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Per-service variables live in backend/.env.example and frontend/.env.example.
# =============================================================================

# ---- Database ----
POSTGRES_DB=iot_platform
POSTGRES_USER=iotadmin
DB_PASSWORD=change-me

# ---- Redis ----
REDIS_PASSWORD=

# ---- JWT (min 32 chars) ----
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Encryption (AES-256, 32-byte hex) ----
ENCRYPTION_KEY=

# ---- External MQTT broker (bring your own) ----
MQTT_HOST=your-broker-host.example.com
MQTT_PORT=1883
MQTT_PROTOCOL=mqtt
MQTT_USERNAME=iot
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=iot-platform-backend
MQTT_TLS_ENABLED=false

# ---- Cloudflare R2 (firmware storage) ----
R2_BUCKET=iot-firmware
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ---- Cloudflare ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
WORKER_URL=https://api.your-domain.com
PAGES_URL=https://app.your-domain.com

# ---- Security / networking ----
CORS_ORIGINS=http://localhost:3000
HOST_IP=localhost

# ---- OTA ----
OTA_SIGNED_URL_EXPIRY=3600

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ---- Grafana (optional monitoring stack) ----
GRAFANA_PASSWORD=admin
