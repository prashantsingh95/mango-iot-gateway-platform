# =============================================================================
# Mango IoT Gateway Agent — environment
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# Gateway identity + secret issued by the backend (POST /gateways/:id/agent-secret)
GATEWAY_ID=
GATEWAY_SECRET=

# Backend WebSocket endpoint the agent dials OUT to (wss://... or ws://...).
BACKEND_WS_URL=ws://localhost:3001

# MUST match the backend TERMINAL_SIGNING_PEPPER exactly.
SIGNING_PEPPER=

# Optional tuning
HEARTBEAT_MS=30000
RECONNECT_BASE_MS=1000
SHELL=/bin/bash
LOG_LEVEL=info
