# =============================================================================
# Mango IoT Gateway Platform — Backend environment
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# The app validates required variables on startup and fails fast if missing.
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://iotadmin:iotpassword@localhost:5432/iot_platform?schema=public

# ----------------------------------------------------------------------------
# Redis (cache + queues)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# JWT — REQUIRED (JWT_SECRET must be at least 32 characters)
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ----------------------------------------------------------------------------
# MQTT — connects to YOUR OWN EXTERNAL broker. No broker is bundled/deployed.
# Supports protocols: mqtt, mqtts, ws, wss
# MQTT_HOST is REQUIRED.
# ----------------------------------------------------------------------------
MQTT_HOST=your-broker-host.example.com
MQTT_PORT=1883
MQTT_PROTOCOL=mqtt
MQTT_USERNAME=iot
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=iot-platform-backend
MQTT_TLS_ENABLED=false
MQTT_CA_FILE=
MQTT_CERT_FILE=
MQTT_KEY_FILE=
# Set to false only for self-signed broker certs in non-production environments.
MQTT_TLS_REJECT_UNAUTHORIZED=true

# ----------------------------------------------------------------------------
# Cloudflare
# ----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ----------------------------------------------------------------------------
# Cloudflare R2 (firmware & file storage) — S3-compatible
# Required together when firmware storage is used.
# ----------------------------------------------------------------------------
R2_BUCKET=iot-firmware
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
R2_REGION=auto

# ----------------------------------------------------------------------------
# Cloudflare Workers / Pages URLs (for CORS / references)
# ----------------------------------------------------------------------------
WORKER_URL=https://api.your-domain.com
PAGES_URL=https://app.your-domain.com

# ----------------------------------------------------------------------------
# Cloudflare Turnstile (optional bot protection)
# ----------------------------------------------------------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Email (SMTP)
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ----------------------------------------------------------------------------
# OTA
# ----------------------------------------------------------------------------
# Lifetime (seconds) of signed R2 firmware download URLs.
OTA_SIGNED_URL_EXPIRY=3600

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
COOKIE_SECURE=false
COOKIE_DOMAIN=
# AES-256 key (32-byte hex) for encrypting sensitive fields at rest.
ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Metrics
# ----------------------------------------------------------------------------
METRICS_ENABLED=false

# ----------------------------------------------------------------------------
# Remote Terminal (reverse-connection gateway agent)
# ----------------------------------------------------------------------------
# HMAC pepper used to derive per-gateway message signing keys. REQUIRED and must
# be shared (identical) with every gateway agent. At least 16 characters.
TERMINAL_SIGNING_PEPPER=change-me-to-a-long-random-pepper-at-least-16-chars
# Public WS URL advertised to gateway agents (wss://...). Defaults to a value
# derived from HOST/PORT if unset.
BACKEND_WS_URL=
# Keep-alive tuning (optional).
TERMINAL_HEARTBEAT_MS=30000
TERMINAL_HEARTBEAT_TIMEOUT_MS=90000
TERMINAL_IDLE_TIMEOUT_MIN=240
