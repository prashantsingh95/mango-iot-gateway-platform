# =============================================================================
# Mango IoT Gateway Platform — Frontend environment
# Copy to `.env.local` and fill in real values.
# =============================================================================

# Base URL of the API. In production point this at the Cloudflare Worker
# API gateway that fronts the NestJS backend.
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL (Socket.IO / SSH terminal).
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Cloudflare Turnstile site key (optional bot protection on auth pages).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Set to `cloudflare` when building for Cloudflare Pages (npm run pages:build).
# Leave unset for the standalone Docker/Node build.
# DEPLOY_TARGET=cloudflare
